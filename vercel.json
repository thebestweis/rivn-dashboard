{
  "routes": [
    {
      "src": "/(?:wp-admin|wp-login\\.php|xmlrpc\\.php|phpmyadmin|\\.env|\\.git)(?:/.*)?",
      "mitigate": {
        "action": "deny"
      }
    },
    {
      "src": "/api/(?:avito/(?:test.*|get-token|get-all-items)|telegram/test.*)",
      "mitigate": {
        "action": "deny"
      }
    }
  ],
  "crons": [
    {
      "path": "/api/cron/payment-reminders",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/daily-tasks",
      "schedule": "0 6 * * *"
    }
  ]
}
